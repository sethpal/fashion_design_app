<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= design.name %> - Fashion Designer Portfolio</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <div class="logo">
                <h1>✨ Fashion Designs ✨</h1>
            </div>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/#categories">Categories</a></li>
                <li><a href="/admin">Admin</a></li>
            </ul>
        </div>
    </nav>

    <main class="container">
        <a href="/" class="back-link">← Back to Home</a>
        
        <section class="design-detail">
            <div class="design-detail-image">
                <img src="<%= design.image %>" alt="<%= design.name %>">
            </div>
            
            <div class="design-detail-info">
                <h1><%= design.name %></h1>
                <p class="category-badge"><%= design.category %></p>
                
                <div class="design-specs">
                    <div class="spec">
                        <strong>Color:</strong>
                        <span><%= design.color %></span>
                    </div>
                    <div class="spec">
                        <strong>Material:</strong>
                        <span><%= design.material %></span>
                    </div>
                    <div class="spec">
                        <strong>Season:</strong>
                        <span><%= design.season %></span>
                    </div>
                </div>
                
                <div class="description-section">
                    <h2>Description</h2>
                    <p><%= design.description %></p>
                </div>
                
                <div class="action-buttons">
                    <button class="btn btn-primary">Inquire About This Design</button>
                    <a href="/" class="btn btn-secondary">Browse More Designs</a>
                </div>
            </div>
        </section>
    </main>

    <footer class="footer">
        <p>&copy; 2026 Fashion Designer Portfolio. All rights reserved.</p>
    </footer>
</body>
</html>
