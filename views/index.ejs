<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fashion Designer Portfolio</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <div class="logo">
                <h1>✨ Fashion Designs ✨</h1>
            </div>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/#categories">Categories</a></li>
                <li><a href="/admin">Admin</a></li>
            </ul>
        </div>
    </nav>

    <header class="hero">
        <div class="hero-content">
            <h1>Welcome to My Design Studio</h1>
            <p>Discover elegant and unique fashion designs</p>
        </div>
    </header>

    <main class="container">
        <section id="designs" class="designs-section">
            <h2>Latest Collections</h2>
            <div class="designs-grid">
                <% designs.forEach(design => { %>
                    <div class="design-card">
                        <div class="design-image">
                            <img src="<%= design.image %>" alt="<%= design.name %>">
                        </div>
                        <div class="design-info">
                            <h3><%= design.name %></h3>
                            <p class="category"><%= design.category %></p>
                            <p class="description"><%= design.description %></p>
                            <div class="design-details">
                                <span class="detail"><strong>Color:</strong> <%= design.color %></span>
                                <span class="detail"><strong>Material:</strong> <%= design.material %></span>
                                <span class="detail"><strong>Season:</strong> <%= design.season %></span>
                            </div>
                            <a href="/design/<%= design.id %>" class="btn btn-primary">View Details</a>
                        </div>
                    </div>
                <% }); %>
            </div>
        </section>

        <section id="categories" class="categories-section">
            <h2>Browse by Category</h2>
            <div class="categories-grid">
                <a href="/category/Dresses" class="category-card">
                    <h3>Dresses</h3>
                </a>
                <a href="/category/Jackets" class="category-card">
                    <h3>Jackets</h3>
                </a>
                <a href="/category/Gowns" class="category-card">
                    <h3>Gowns</h3>
                </a>
                <a href="/category/Bottoms" class="category-card">
                    <h3>Bottoms</h3>
                </a>
                <a href="/category/Tops" class="category-card">
                    <h3>Tops</h3>
                </a>
                <a href="/category/Skirts" class="category-card">
                    <h3>Skirts</h3>
                </a>
            </div>
        </section>
    </main>

    <footer class="footer">
        <p>&copy; 2026 Fashion Designer Portfolio. All rights reserved.</p>
    </footer>
</body>
</html>
